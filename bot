async def show_phrase(query, part_key: str, phrase_idx: int, version: int = 1):
    part = get_part_by_key(version, part_key)
    if not part:
        await query.edit_message_text("❌ Часть не найдена.")
        return
    
    # Получаем выученные фразы пользователя
    user_data = get_user(query.from_user.id)
    learned = user_data.get("learned", [])
    
    # Получаем все фразы части
    all_phrases = part["phrases"]
    total = len(all_phrases)
    
    # Находим следующую невыученную фразу
    current_idx = phrase_idx
    while current_idx < total:
        key = f"{part_key}_{current_idx}"
        if key not in learned:
            break
        current_idx += 1
    
    # Если все фразы выучены
    if current_idx >= total:
        await query.edit_message_text(
            f"🎉 *Поздравляю!* Вы выучили все фразы в этой части!\n\n"
            f"📚 {part['title']} — полностью завершена! 🌟\n\n"
            f"Перейдите к следующей части или вернитесь в меню.",
            parse_mode="Markdown",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("📚 Следующая часть", callback_data="next_part")],
                [InlineKeyboardButton("🏠 Главное меню", callback_data="main_menu")],
            ])
        )
        return
    
    # Показываем текущую невыученную фразу
    phrase = all_phrases[current_idx]
    remaining = total - len([k for k in learned if k.startswith(f"{part_key}_")])
    
    text = (
        f"{part['title']} — осталось {remaining} фраз\n\n"
        f"🇮🇱 *Иврит:*\n"
        f"```\n{phrase['he']}\n```\n\n"
        f"🔤 *Транслитерация:*\n_{phrase['translit']}_\n\n"
        f"🇷🇺 *По-русски:*\n{phrase['ru']}"
    )

    # Добавляем пример для версии 2
    if version == 2 and "example" in phrase and phrase["example"]:
        text += f"\n\n📝 *Пример:*\n_{phrase['example']}_"

    await query.edit_message_text(
        text,
        parse_mode="Markdown",
        reply_markup=phrase_keyboard(part_key, current_idx, total, version)
    )

