def get_course_parts(version: int) -> dict:
    """Возвращает структуру курса для заданной версии"""
    if version == 1:
        # Вариант 1: только настоящее время
        return {
            "part1": {
                "title": "📘 Часть 1",
                "phrases": (
                    GREETINGS +
                    NUMBERS_V1[:10] +  # 1-10
                    VERBS_V1_ALL[:10] +  # 10 глаголов
                    WORDS_ALL[:100]  # 100 слов
                )
            },
            "part2": {
                "title": "📗 Часть 2",
                "phrases": (
                    NUMBERS_V1[10:101] +  # 11-101
                    VERBS_V1_ALL[10:60] +  # ещё 50 глаголов
                    WORDS_ALL[100:300]  # ещё 200 слов
                )
            },
            "part3": {
                "title": "📕 Часть 3",
                "phrases": (
                    NUMBERS_V1[101:] +  # остальные числа до 100000000
                    WORDS_ALL[300:]  # остальные слова
                )
            }
        }
    else:
        # Вариант 2: три времени
        return {
            "part1": {
                "title": "📘 Часть 1",
                "phrases": (
                    GREETINGS +
                    NUMBERS_V1[:100] +  # 1-100
                    VERBS_V2_ALL[:10] +  # 10 глаголов в 3-х временах
                    WORDS_ALL[:100]  # 100 слов
                )
            },
            "part2": {
                "title": "📗 Часть 2",
                "phrases": (
                    NUMBERS_V1[100:132] +  # 101-10001
                    VERBS_V2_ALL[10:60] +  # ещё 50 глаголов
                    WORDS_ALL[100:400]  # ещё 300 слов
                )
            },
            "part3": {
                "title": "📕 Часть 3",
                "phrases": (
                    NUMBERS_V1[132:] +  # остальные числа до 100000000
                    VERBS_V2_ALL[60:] +  # остальные глаголы
                    WORDS_ALL[400:]  # остальные слова
                )
            }
        }

def get_part_by_key(version: int, part_key: str) -> dict:
    """Возвращает часть курса по ключу"""
    parts = get_course_parts(version)
    return parts.get(part_key)

def get_phrase_by_key_v2(version: int, part_key: str, phrase_idx: int) -> dict:
    """Возвращает фразу по ключу части и индексу"""
    part = get_part_by_key(version, part_key)
    if not part:
        return None
    try:
        phrases = part.get("phrases", [])
        if phrase_idx < len(phrases):
            return phrases[phrase_idx]
        return None
    except (IndexError, KeyError):
        return None

def get_quiz_pool_v2(version: int, part_key: str) -> list:
    """Возвращает пул фраз для теста из конкретной части"""
    part = get_part_by_key(version, part_key)
    if part:
        return part.get("phrases", [])
    return []

